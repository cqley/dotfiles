[global]
    origin = top-right
    offset = (15, 15)
    monitor = 1
    follow = none
    width = 250
    height = (0, 75)
    frame_width = 2
    frame_color = "#ffffff"
    corner_radius = 0
    background = "#000000"
    foreground = "#ffffff"
    separator_color = frame
    separator_height = 2
    padding = 15
    horizontal_padding = 20
    icon_position = left
    max_icon_size = 32
    markup = full
    format = "<span foreground='#ffffff'><b>%s</b></span>\n%b"
    alignment = left
    word_wrap = yes
    sort = no
    stack_duplicates = false
    notification_limit = 1
    indicate_hidden = yes
    overlap_hide = no
    override_dbus_timeout = 3

[urgency_critical]
    background = "#ff0000"
    foreground = "#ffffff"
    frame_color = "#ffffff"
    override_dbus_timeout = 5
