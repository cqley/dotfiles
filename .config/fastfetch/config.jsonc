{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "none",
    "type": "builtin",
  },

  "display": {
    "separator": ": ",
    "key": {
      "width": 11,
    },
  },

  "modules": [
    {
      "type": "kernel",
      "key": "kernel",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "wm",
      "key": "wm",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "uptime",
      "key": "uptime",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "shell",
      "key": "shell",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "terminal",
      "key": "terminal",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "cpu",
      "key": "cpu",
      "keyColor": "#FFB6C1",
    },
    {
      "type": "memory",
      "key": "memory",
      "keyColor": "#FFB6C1",
    },
  ],
}
